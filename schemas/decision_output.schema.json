{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/ai-emergency-commander/decision_output.schema.json",
  "title": "AI Emergency Commander Decision Output",
  "type": "object",
  "required": ["scenario_id", "run_mode", "bayesian_model", "weights_used", "zone_assessment", "assignments", "routes", "utility_matrix", "unit_states", "simulation_clock", "timeline", "replan_log"],
  "properties": {
    "scenario_id": {"type": "string"},
    "run_mode": {"enum": ["fixed", "learned"]},
    "bayesian_model": {"type": "string", "minLength": 1},
    "weights_used": {"type": "object"},
    "zone_assessment": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["zone_id", "node_id", "trapped_prob", "passability_prob", "life_risk", "priority_score"],
        "properties": {
          "zone_id": {"type": "string"},
          "node_id": {"type": "string"},
          "trapped_prob": {"type": "number", "minimum": 0, "maximum": 1},
          "passability_prob": {"type": "number", "minimum": 0, "maximum": 1},
          "life_risk": {"type": "number", "minimum": 0, "maximum": 1},
          "priority_score": {"type": "number", "minimum": 0, "maximum": 1}
          ,"inference_model": {"type": "string"}
          ,"bayesian_evidence": {"type": "object"}
          ,"trapped_explanation": {"type": "object"}
          ,"passability_explanation": {"type": "object"}
        },
        "additionalProperties": false
      }
    },
    "assignments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["unit_id", "target_zone", "mission_type", "expected_utility", "reason", "feasibility_reason", "explanation", "resource_cost", "utility_inputs", "utility_breakdown"],
        "properties": {
          "unit_id": {"type": "string"},
          "target_zone": {"type": "string"},
          "mission_type": {"enum": ["rescue", "reconnaissance"]},
          "expected_utility": {"type": "number"},
          "reason": {"type": "string"},
          "feasibility_reason": {"type": "string"},
          "explanation": {"type": "string"},
          "resource_cost": {"type": "number", "minimum": 0, "maximum": 1},
          "utility_inputs": {"$ref": "#/$defs/utilityInputs"},
          "utility_breakdown": {"$ref": "#/$defs/utilityBreakdown"}
          ,"estimated_people": {"type": "integer", "minimum": 0}
          ,"unit_status": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["unit_id", "target_zone", "path", "road_ids", "eta", "path_risk"],
        "properties": {
          "unit_id": {"type": "string"},
          "target_zone": {"type": "string"},
          "path": {"type": "array", "items": {"type": "string"}},
          "road_ids": {"type": "array", "items": {"type": "string"}},
          "eta": {"type": "number", "minimum": 0},
          "path_risk": {"type": "number", "minimum": 0, "maximum": 1}
          ,"mission_type": {"type": "string"}
          ,"remaining_eta": {"type": "number", "minimum": 0}
          ,"route_layer": {"enum": ["ground", "air"]}
          ,"heuristic": {"type": "string"}
          ,"expanded_nodes": {"type": "integer", "minimum": 0}
        },
        "additionalProperties": false
      }
    },
    "utility_matrix": {
      "type": "array",
      "items": {"$ref": "#/$defs/utilityCandidate"}
    },
    "unit_states": {"type": "object"},
    "simulation_clock": {"type": "number", "minimum": 0},
    "timeline": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["step", "clock_minutes", "event", "plan", "unit_states", "scenario_state"],
        "properties": {
          "step": {"type": "integer", "minimum": 0},
          "clock_minutes": {"type": "number", "minimum": 0},
          "event": {"type": ["object", "null"]},
          "plan": {"type": "object"},
          "unit_states": {"type": "object"},
          "scenario_state": {"type": "object"}
        },
        "additionalProperties": false
      }
    },
    "replan_log": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["trigger_event", "old_plan", "new_plan", "reason"],
        "properties": {
          "trigger_event": {"type": "object"},
          "clock_minutes": {"type": "number", "minimum": 0},
          "old_plan": {"type": "object"},
          "new_plan": {"type": "object"},
          "reason": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "utilityInputs": {
      "type": "object",
      "required": ["trapped_prob", "life_risk", "accessibility", "arrival_time_normalized", "path_risk", "resource_cost"],
      "properties": {
        "trapped_prob": {"type": "number"},
        "life_risk": {"type": "number"},
        "accessibility": {"type": "number"},
        "arrival_time_normalized": {"type": "number"},
        "path_risk": {"type": "number"},
        "resource_cost": {"type": "number"}
      },
      "additionalProperties": false
    },
    "utilityBreakdown": {
      "type": "object",
      "required": ["trapped_benefit", "life_risk_benefit", "accessibility_benefit", "arrival_time_cost", "path_risk_cost", "resource_cost"],
      "properties": {
        "trapped_benefit": {"type": "number"},
        "life_risk_benefit": {"type": "number"},
        "accessibility_benefit": {"type": "number"},
        "arrival_time_cost": {"type": "number"},
        "path_risk_cost": {"type": "number"},
        "resource_cost": {"type": "number"}
      },
      "additionalProperties": false
    },
    "utilityCandidate": {
      "type": "object",
      "required": ["unit_id", "unit_type", "target_zone", "mission_type", "feasible", "reason", "explanation", "resource_cost", "utility_inputs", "utility_breakdown", "expected_utility", "route"],
      "properties": {
        "unit_id": {"type": "string"},
        "unit_type": {"enum": ["rescue_car", "drone"]},
        "target_zone": {"type": "string"},
        "mission_type": {"enum": ["rescue", "reconnaissance"]},
        "feasible": {"type": "boolean"},
        "reason": {"type": "string"},
        "explanation": {"type": "string"},
        "resource_cost": {"type": "number", "minimum": 0, "maximum": 1},
        "utility_inputs": {
          "oneOf": [
            {"$ref": "#/$defs/utilityInputs"},
            {"type": "null"}
          ]
        },
        "utility_breakdown": {
          "oneOf": [
            {"$ref": "#/$defs/utilityBreakdown"},
            {"type": "null"}
          ]
        },
        "expected_utility": {"type": ["number", "null"]},
        "route": {"type": ["object", "null"]}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
